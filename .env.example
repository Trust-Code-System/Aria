# ============================================================================
# Aria — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`. Only server-side vars have access to secrets.
# The app degrades gracefully when optional keys are missing (features show a
# clear "not configured" state instead of crashing).
# ============================================================================

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development

# --- Supabase (required for auth, database, storage) -----------------------
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — used only in trusted server code for admin/ingest jobs.
SUPABASE_SERVICE_ROLE_KEY=

# --- LLM Providers (at least one recommended for chat/RAG) -----------------
# The provider abstraction picks a provider from the model id prefix.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Web Research providers (optional; at least one enables research mode) --
PERPLEXITY_API_KEY=
TAVILY_API_KEY=

# --- Model defaults --------------------------------------------------------
# Format: "<provider>:<model>". Current recommended models are shown in Settings.
DEFAULT_CHAT_MODEL=openai:gpt-5.6
# Embedding model. Must match the vector dimension in the DB migration (1536 for text-embedding-3-small).
DEFAULT_EMBEDDING_MODEL=openai:text-embedding-3-small
# Web research model (only used if a research provider key is present)
DEFAULT_RESEARCH_MODEL=perplexity:sonar
# Role-based routing — greetings / short rewrites use FAST_MODEL when set.
FAST_MODEL=google:gemini-3.5-flash
# Email/send and other tool actions (avoid OpenAI when it is out of quota).
ACTION_MODEL=google:gemini-3.5-flash
# DEFAULT_MODEL=
# REASONING_MODEL=
# CODING_MODEL=
# VISION_MODEL=

# --- Connectors (Composio; optional, enables the Connections page + Cowork) --
COMPOSIO_API_KEY=
COMPOSIO_GMAIL_AUTH_CONFIG_ID=
COMPOSIO_GOOGLE_CALENDAR_AUTH_CONFIG_ID=
COMPOSIO_GOOGLE_DRIVE_AUTH_CONFIG_ID=
COMPOSIO_SLACK_AUTH_CONFIG_ID=
COMPOSIO_NOTION_AUTH_CONFIG_ID=
COMPOSIO_GITHUB_AUTH_CONFIG_ID=
COMPOSIO_LINEAR_AUTH_CONFIG_ID=
COMPOSIO_JIRA_AUTH_CONFIG_ID=
COMPOSIO_TRELLO_AUTH_CONFIG_ID=
COMPOSIO_ASANA_AUTH_CONFIG_ID=
COMPOSIO_HUBSPOT_AUTH_CONFIG_ID=
COMPOSIO_SALESFORCE_AUTH_CONFIG_ID=
COMPOSIO_OUTLOOK_AUTH_CONFIG_ID=
COMPOSIO_BASE_URL=

# --- Telemetry (optional; metadata only — model/latency/tokens, no content) --
# Set both keys to enable Langfuse tracing. Self-host by setting LANGFUSE_HOST.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# --- E2E tests (npm run test:e2e; optional) ---------------------------------
# Base URL of a RUNNING app. Authed specs need a real login; they skip cleanly
# when the credentials are missing.
E2E_BASE_URL=http://localhost:3000
E2E_EMAIL=
E2E_PASSWORD=

# --- Retrieval eval (npm run eval:retrieval; optional) ----------------------
# A real login for the eval script — RLS applies, so it only sees this user's
# workspace. Point EVAL_WORKSPACE_ID at the workspace holding your test corpus.
EVAL_USER_EMAIL=
EVAL_USER_PASSWORD=
EVAL_WORKSPACE_ID=

# --- Admin -----------------------------------------------------------------
# Comma-separated list of emails allowed into /admin (e.g. you@example.com).
ADMIN_EMAIL=

# TEMPORARY: set true to skip login and use ADMIN_EMAIL's account (needs service
# role). Anyone with the app URL gets that access — keep false for normal auth.
AUTH_DISABLED=false

# --- Voice (optional) ------------------------------------------------------
# Speech-to-text (mic) and read-aloud work in-browser with NO keys (Web Speech
# API + speechSynthesis). These keys unlock higher-quality / realtime voice —
# see lib/voice/providers.ts and docs/VOICE_SYSTEM.md. Leave blank to use the
# browser fallback.
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
# OpenAI Realtime API reuses OPENAI_API_KEY above.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# --- Limits (optional; sensible defaults applied in code) ------------------
MAX_UPLOAD_MB=25

# --- Privacy: LLM training logs (opt-in) ------------------------------------
# Off by default. When true, chat turns are written to llm_training_logs for
# future personal fine-tuning. Run `node scripts/cleanup-training-logs.js`
# periodically (or via cron) to enforce TTL.
LLM_TRAINING_LOGS_ENABLED=false
LLM_TRAINING_LOGS_TTL_DAYS=30

# --- Background jobs -------------------------------------------------------
# true (default): enqueue then process inline (good for next start / single node).
# false: only enqueue; call POST /api/jobs/drain from cron / Trigger.dev.
JOBS_INLINE=true
